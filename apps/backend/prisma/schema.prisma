generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               Int      @id @default(autoincrement())
  shortId          String   @unique
  role             String   @default("USER")
  stellarPublicKey String   @unique
  offlineDeviceKey String?
  pin              String?
  phoneNumber      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model Settlement {
  id              Int      @id @default(autoincrement())
  senderShortId   String
  receiverShortId String
  relayerAddress  String?
  amountToken     String
  txHash          String?
  status          String
  createdAt       DateTime @default(now())
}

model GatewayNode {
  id               Int      @id @default(autoincrement())
  name             String
  stellarPublicKey String   @unique
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
}
