{
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "build:sdk": "npm install && npm run build --workspace=pijin_core && npm install --workspace=backend"
  },
  "lint-staged": {
      "apps/backend/**/*.{js,jsx,ts,tsx}": [
        "eslint --fix",
        "prettier --write"
      ],
      "apps/mobile/**/*.{js,jsx,ts,tsx}": [
        "eslint --fix",
        "prettier --write"
      ],
      "contracts/**/*.rs": "cargo fmt --"
    }
}
