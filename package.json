{
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.0.0"
  },
  "scripts": {
    "prepare": "node -e \"if (process.env.CI !== 'true') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\"",
    "lint-staged": "lint-staged",
    "build:sdk": "npm install && npm run build --workspace=pijin_core && npm install --workspace=backend",
    "typecheck": "npm run typecheck --workspace=backend --workspace=pijin_core"
  },
  "lint-staged": {
    "apps/backend/**/*.{ts,tsx}": [],
    "packages/pijin_core/**/*.ts": [],
    "apps/backend/**/*.{js,jsx}": [],
    "apps/mobile/**/*.{js,jsx,ts,tsx}": [],
    "contracts/**/*.rs": "cargo fmt --manifest-path contracts/Cargo.toml --"
  },
  "overrides": {
    "react-native": "0.76.9",
    "expo": "52.0.49",
    "expo-media-library": "17.0.5",
    "metro": "0.80.12",
    "metro-cache": "0.80.12",
    "metro-config": "0.80.12",
    "metro-core": "0.80.12",
    "metro-resolver": "0.80.12",
    "metro-transform-worker": "0.80.12"
  }
}
