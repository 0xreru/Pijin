{
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "overrides": {
    "react-native": "0.76.9",
    "expo": "52.0.49",
    "expo-media-library": "17.0.5"
  },
  "scripts": {
    "prepare": "node -e \"if (process.env.CI !== 'true') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\"",
    "lint-staged": "lint-staged",
    "build:sdk": "npm install && npm run build --workspace=pijin_core && npm install --workspace=backend",
    "typecheck": "npm run typecheck --workspace=backend --workspace=pijin_core"
  },
  "lint-staged": {
      "apps/backend/**/*.{ts,tsx}": [],
      "packages/pijin_core/**/*.ts": [],
      "apps/backend/**/*.{js,jsx}": [],
      "apps/mobile/**/*.{js,jsx,ts,tsx}": [],
      "contracts/**/*.rs": "cargo fmt --"
    },
  "overrides": {
    "metro": "^0.81.0",
    "metro-cache": "^0.81.0",
    "metro-config": "^0.81.0",
    "metro-core": "^0.81.0",
    "metro-resolver": "^0.81.0"
  }
}
